# ============================================================
# PRODUCTION CHECKLIST — change ALL of these before deploying:
#
#   1. POSTGRES_PASSWORD  (default: devpulse)
#   2. JWT_SECRET         (generate: openssl rand -hex 32)
#   3. ENCRYPTION_KEY     (generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
#   4. GITHUB_WEBHOOK_SECRET (generate: openssl rand -hex 32)
#   5. GITHUB_APP_ID / INSTALLATION_ID / PRIVATE_KEY_PATH
#   6. GITHUB_CLIENT_ID / CLIENT_SECRET
#   7. GITHUB_ORG
#   8. DEVPULSE_INITIAL_ADMIN
#   9. FRONTEND_URL       (https://your-domain)
#  10. ENVIRONMENT=production
#  11. LOG_FORMAT=json
#  12. SENTINEL_URL / SENTINEL_SECRET (for error monitoring)
#  13. GF_ADMIN_PASSWORD  (if using observability stack)
# ============================================================

# Database
# IMPORTANT: Change the default password for any network-accessible deployment
DATABASE_URL=postgresql+asyncpg://devpulse:devpulse@localhost:5432/devpulse

# PostgreSQL password — used by both the db container and backend DATABASE_URL.
# The docker-compose.yml references this via ${POSTGRES_PASSWORD:-devpulse}.
# CHANGE THIS for any non-local deployment.
# Generate with: openssl rand -hex 16
POSTGRES_PASSWORD=devpulse

# GitHub App
GITHUB_APP_ID=12345
GITHUB_APP_PRIVATE_KEY_PATH=./github-app.pem
# Docker host path to the .pem file (mounted into the container).
# In production: /etc/devpulse/github-app.pem
# docker-compose.yml overrides GITHUB_APP_PRIVATE_KEY_PATH inside the container.
GITHUB_APP_PEM_HOST_PATH=./github-app.pem
GITHUB_APP_INSTALLATION_ID=67890
# Generate with: openssl rand -hex 32
GITHUB_WEBHOOK_SECRET=whsec_your-webhook-secret
# Optional display label. Repo discovery now uses /installation/repositories so any User or Org
# installation works regardless of this value. Leave blank for personal-account installations.
GITHUB_ORG=

# GitHub OAuth (from GitHub App settings → OAuth)
GITHUB_CLIENT_ID=Iv1.xxxxxxxxxxxx
GITHUB_CLIENT_SECRET=xxxxxxxxxxxxxxxxxxxx

# Auth
# REQUIRED: Must be at least 32 characters. Generate with: openssl rand -hex 32
JWT_SECRET=generate-a-random-secret-here
# Initial admin: set to your GitHub username for first-time setup.
# Automatically ignored after the first admin account is created.
DEVPULSE_INITIAL_ADMIN=your-github-username
# Sign-in allowlist: comma-separated GitHub usernames permitted to OAuth in (case-insensitive).
# Preferred over GITHUB_ORG for User-account installations. If neither DEVPULSE_ALLOWED_USERS
# nor GITHUB_ORG is set, sign-in fails closed.
DEVPULSE_ALLOWED_USERS=your-github-username
FRONTEND_URL=http://localhost:3001
# Production: use https:// and match your domain.
# Nordlabs production: FRONTEND_URL=https://devpulse.claros.no
# TLS should be terminated by a reverse proxy (nginx, Caddy, Traefik) in front of the backend.
# Update CORS allow_origins (FRONTEND_URL) to match the production domain.

# Encryption (required for Slack bot token and Linear API key storage)
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Grafana (optional — only needed with --profile logging)
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=devpulse

# Environment
ENVIRONMENT=development  # "development" or "production"
                         # Production mode: enables HSTS, disables /docs and /redoc

# Logging
LOG_FORMAT=console       # "json" for production (Docker), "console" for local dev
LOG_LEVEL=INFO           # DEBUG, INFO, WARNING, ERROR

# Rate Limiting
RATE_LIMIT_ENABLED=true  # Set to "false" to disable (e.g. in tests)
# For multi-instance deployments, configure a Redis backend for slowapi:
# RATELIMIT_STORAGE_URI=redis://localhost:6379

# AI (optional — only needed if you want AI analysis)
ANTHROPIC_API_KEY=sk-ant-...

# Sync
SYNC_INTERVAL_MINUTES=15
FULL_SYNC_CRON_HOUR=2

# Linear Integration (optional — configure via UI or env var)
# Sync interval in minutes (default 120 = 2 hours)
LINEAR_SYNC_INTERVAL_MINUTES=120

# Sentinel Error Reporting (required for production error monitoring)
# SENTINEL_URL is the base URL of the Sentinel service
SENTINEL_URL=https://sentinel.claros.no
# SENTINEL_SECRET is the HMAC shared secret — must match the value in Sentinel
# Generate with: openssl rand -hex 32
SENTINEL_SECRET=

# Version metadata (auto-injected during Docker builds via deploy.sh)
# Normally you do NOT set these manually — they are computed from VERSION file and git.
# DEVPULSE_VERSION=0.1.0
# DEVPULSE_BUILD_NUMBER=0
# DEVPULSE_COMMIT_SHA=unknown
# DEVPULSE_DEPLOY_TIME=unknown

# DORA Metrics (optional — leave DEPLOY_WORKFLOW_NAME empty to disable)
DEPLOY_WORKFLOW_NAME=
DEPLOY_ENVIRONMENT=production
# CFR failure detection — comma-separated PR labels and branch prefixes that indicate hotfixes
HOTFIX_LABELS=hotfix,urgent,incident
HOTFIX_BRANCH_PREFIXES=hotfix/
